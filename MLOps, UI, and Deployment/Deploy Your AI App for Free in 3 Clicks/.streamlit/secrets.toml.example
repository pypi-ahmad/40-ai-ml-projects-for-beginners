# Copy this file to .streamlit/secrets.toml for local testing.
# Never commit .streamlit/secrets.toml with real secrets.

HF_API_TOKEN = "your_hugging_face_token_here"
OLLAMA_BASE_URL = "http://localhost:11434"

# Optional local model overrides (Ollama tags)
SENTIMENT_MODEL = "qwen3.5:2b"
SENTIMENT_MODEL_ALT = "qwen3.5:4b"
SUMMARIZATION_MODEL = "granite4.1:3b"
CLASSIFICATION_MODEL = "nemotron-3-nano:4b"
TRANSLATION_MODEL = "translategemma:4b"

# Optional validation limits
MIN_TEXT_LENGTH = 3
MAX_TEXT_LENGTH = 5000
MAX_CATEGORIES = 20
MAX_CATEGORY_LENGTH = 32
